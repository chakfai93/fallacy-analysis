{\n  "manifest_version": 3,\n  "name": "Fallacy Analysis Extension",\n  "version": "1.0",\n  "description": "Analyze web content for logical fallacies",\n  "permissions": [\n    "storage",\n    "activeTab",\n    "scripting"\n  ],\n  "host_permissions": [\n    "<all_urls>"\n  ],\n  "background": {\n    "service_worker": "background/service-worker.js"\n  },\n  "action": {\n    "default_popup": "popup/popup.html",\n    "default_title": "Fallacy Analysis"\n  },\n  "icons": {\n    "16": "icons/icon16.png",\n    "48": "icons/icon48.png",\n    "128": "icons/icon128.png"\n  },\n  "content_scripts": [\n    {\n      "matches": [\n        "<all_urls>"\n      ],\n      "js": [\n        "content/content.js"\n      ]\n    }\n  ]\n}