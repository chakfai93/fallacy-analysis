{\n  "manifest_version": 3,\n  "name": "My Chrome Extension",\n  "version": "1.0",\n  "description": "A Chrome Extension for analyzing logical fallacies",\n  "permissions": ["storage", "activeTab"],\n  "background": {\n    "service_worker": "background.js"\n  },\n  "action": {\n    "default_popup": "popup.html",\n    "default_icon": "icon.png"\n  },\n  "icons": {\n    "16": "icon_16.png",\n    "48": "icon_48.png",\n    "128": "icon_128.png"\n  },\n  "content_scripts": [\n    {\n      "matches": ["<all_urls>"],\n      "js": ["content.js"]\n    }\n  ]\n}